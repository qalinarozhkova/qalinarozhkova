    {
      "name": "Users",
      "item": [
        {
          "name": "Авторизация пользователя",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {\r",
                  "    const responseData = pm.response.json();\r",
                  "    const authToken = responseData.key; // <-- Забираем значение из поля \"key\"\r",
                  "    \r",
                  "    if (authToken) {\r",
                  "        pm.collectionVariables.set(\"token\", authToken); // Сохраняем в переменную (название переменной можете оставить token)\r",
                  "        pm.collectionVariables.set(\"token_time\", Date.now());\r",
                  "        console.log(\"Токен сохранен:\", authToken);\r",
                  "    } else {\r",
                  "        console.log(\"Поле 'key' не найдено в ответе\");\r",
                  "    }\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
